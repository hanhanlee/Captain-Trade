# FinMind API Token（免費註冊：https://finmindtrade.com/）
FINMIND_TOKEN=your_finmind_token_here

# LINE Messaging API（LINE Developers Console 設定）
# 1. 建立 Messaging API Channel，取得 Channel Access Token（長期）
# 2. 將 Bot 加為好友後，取得你的 User ID（格式：Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot 推播（BotFather 建立 bot 後取得）
# TELEGRAM_BOT_TOKEN    ← BotFather 給的 token
# TELEGRAM_STOCK_CHAT_ID ← 股票警示群組 / 頻道 ID（負數 = 群組，正數 = 個人）
# TELEGRAM_SYSTEM_CHAT_ID ← 系統訊息頻道（選填；未設定時 fallback 到 STOCK）
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_STOCK_CHAT_ID=your_chat_id_here
TELEGRAM_SYSTEM_CHAT_ID=

# Google Drive 備份（backup_gdrive.py）
# TELEGRAM_CHAT_ID  ← 備份錯誤通知的 chat id（未設定時 fallback 到 SYSTEM → STOCK）
TELEGRAM_CHAT_ID=
